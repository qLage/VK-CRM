# Development environment variables (native Windows, no Docker)
NODE_ENV=development

# Database — local PostgreSQL (install from https://www.postgresql.org/download/windows/)
# After install, create DB and user:
#   psql -U postgres
#   CREATE USER crm_user WITH PASSWORD 'crm_dev_password';
#   CREATE DATABASE crm OWNER crm_user;
DATABASE_URL=postgresql://work@localhost:5432/crm_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crm_db
DB_USER=work
DB_PASSWORD=
DISABLE_SEEDING=true
PURGE_DATABASE=false

# Redis — не нужен для dev, backend автоматически использует in-memory cache
# REDIS_URL=

# JWT
JWT_SECRET=local_dev_jwt_secret_do_not_use_in_production_2026
JWT_EXPIRES_IN=365d

# Server
PORT=5000
FRONTEND_URL=http://localhost:8080

# S3 (production Selectel bucket — осторожно, пишет в реальное хранилище)
S3_ENDPOINT=https://s3.ru-7.storage.selcloud.ru
