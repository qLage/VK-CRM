{
    "name": "crm-backend",
    "version": "1.0.0",
    "description": "Backend API for Ваша Крыша CRM",
    "main": "dist/server.js",
    "scripts": {
        "start": "node dist/server.js",
        "apply-fix": "tsx src/db/apply_migration_now.ts",
        "dev": "tsx watch src/server.ts",
        "typecheck": "tsc --noEmit",
        "prebuild": "npm run typecheck",
        "build": "tsup src/server.ts --format cjs --clean",
        "postbuild": "echo '✅ Build complete. Output in dist/'",
        "migrate": "tsx src/db/migrate.js",
        "migrate:is-forced": "tsx scripts/migrate-is-forced.ts",
        "migrate:pg": "tsx src/db/migrate_pg.js",
        "migrate:drizzle": "tsx src/db/migrate-drizzle.ts",
        "seed": "tsx src/db/seed.js",
        "setup": "tsx src/db/migrate.js && tsx src/db/seed.js",
        "db:baseline": "tsx scripts/performance-baseline.js",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:push": "drizzle-kit push",
        "db:studio": "drizzle-kit studio",
        "db:introspect": "drizzle-kit introspect",
        "test": "jest --runInBand",
        "test:watch": "jest --watch --runInBand",
        "test:coverage": "jest --coverage --runInBand --coverageReporters=text --coverageReporters=lcov",
        "test:verbose": "jest --verbose --runInBand",
        "test:integration": "jest --testMatch='**/*.integration.test.js' --runInBand",
        "test:unit": "jest --testMatch='**/*.test.js' --testPathIgnorePatterns='integration' --runInBand"
    },
    "keywords": [
        "crm",
        "real-estate",
        "api"
    ],
    "author": "Ваша Крыша",
    "license": "MIT",
    "dependencies": {
        "@aws-sdk/client-s3": "^3.450.0",
        "@aws-sdk/lib-storage": "^3.450.0",
        "@aws-sdk/s3-request-presigner": "^3.450.0",
        "bcryptjs": "^2.4.3",
        "better-sqlite3": "^12.6.2",
        "compression": "^1.7.4",
        "cors": "^2.8.5",
        "date-fns": "^3.6.0",
        "decimal.js": "^10.6.0",
        "dockerode": "^4.0.2",
        "dotenv": "^16.3.1",
        "drizzle-orm": "^0.36.4",
        "exceljs": "^4.4.0",
        "express": "^4.18.2",
        "express-rate-limit": "^8.2.1",
        "express-validator": "^7.0.1",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "multer": "^1.4.5-lts.1",
        "node-cron": "^3.0.3",
        "pg": "^8.18.0",
        "sharp": "^0.34.5",
        "telegraf": "^4.16.3",
        "transliteration": "^2.6.1",
        "ts-node": "^10.9.2",
        "uuid": "^13.0.0",
        "web-push": "^3.6.7",
        "ws": "^8.18.0"
    },
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@babel/preset-env": "^7.29.2",
        "@types/bcryptjs": "^2.4.6",
        "@types/better-sqlite3": "^7.6.13",
        "@types/compression": "^1.8.1",
        "@types/cors": "^2.8.19",
        "@types/decimal.js": "^0.0.32",
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/morgan": "^1.9.10",
        "@types/multer": "^1.4.13",
        "@types/node": "^22.19.15",
        "@types/node-cron": "^3.0.11",
        "@types/pg": "^8.18.0",
        "@types/supertest": "^7.2.0",
        "@types/uuid": "^10.0.0",
        "@types/web-push": "^3.6.4",
        "@types/ws": "^8.18.1",
        "babel-jest": "^30.3.0",
        "drizzle-kit": "^0.28.1",
        "jest": "^30.3.0",
        "nodemon": "^3.0.2",
        "supertest": "^7.2.2",
        "tsup": "^8.5.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    }
}
